---
import type { Card } from "../data/cards";

interface Props {
  card: Card;
  "data-set"?: string;
}

const { card, ...props } = Astro.props;
const hasSource = card.source.length > 0;
const hasImage = card.image.length > 0;
---

<article class="card" {...props}>
  <div class="content">
    <a
      class="card-link"
      href={hasSource ? card.source : "#"}
      aria-disabled={!hasSource || undefined}
    >
      <div class="art">
        {
          hasImage ? (
            <img src={card.image} alt={card.title} loading="lazy" />
          ) : (
            <div class="art-placeholder">No image</div>
          )
        }
      </div>
      <div class="meta">
        <h2 class="title">{card.title}</h2>
      </div>
    </a>
    <div class="actions">
      {
        card.audios.map((clip) => (
          <button
            class="button"
            type="button"
            data-state="idle"
            data-label={clip.label}
            data-path={clip.path}
            data-title={card.title}
            aria-pressed="false"
            aria-label={`Play audio: ${card.title} - ${clip.label}`}
          >
            <img src="/ui/play-button.png" alt="" class="play-icon" />
          </button>
        ))
      }
    </div>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: transparent;
    border: 1px solid var(--hs-border-subtle);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--hs-shadow);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    border-color: var(--hs-border-strong);
  }

  .card:focus-within {
    outline: 3px solid var(--hs-gold-primary);
    outline-offset: 4px;
  }

  .content {
    display: grid;
    gap: 1rem;
  }

  .card-link {
    display: grid;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .card-link[aria-disabled="true"] {
    cursor: default;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--hs-gold-primary);
    outline-offset: 2px;
  }

  .art {
    border-radius: 12px;
    overflow: hidden;
  }

  .art img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .art-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--hs-text-secondary);
    font-size: 0.9rem;
  }

  .meta {
    display: grid;
    padding: 0 1rem;
    gap: 0.5rem;
  }

  .title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    color: var(--hs-text-primary);
    font-family: var(--hs-font-heading);
    transition: color 0.3s ease;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    margin: 0.5rem 1.9rem 1rem;
    min-height: 54px;
    padding: 6px 0;
    position: relative;
    background: url("/ui/bg_component_middle_tile.png") center center repeat-x;
  }

  .actions::before,
  .actions::after {
    content: "";
    position: absolute;
    top: 0;
    width: 34px;
    height: 54px;
    pointer-events: none;
  }

  .actions::before {
    left: -30px;
    background: url("/ui/bg_component_left.png") center left no-repeat;
  }

  .actions::after {
    right: -30px;
    z-index: -1;
    background: url("/ui/bg_component_right.png") center right no-repeat;
  }

  .button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 34px;
    min-height: 34px;
    padding: 0;
    border: 0;
    flex: 0 0 36px;
    cursor: pointer;
    position: relative;
    z-index: 2;
    background: url("/ui/play-button.png") center center no-repeat;
    background-size: contain;
  }

  .play-icon {
    width: 54%;
    object-fit: contain;
    pointer-events: none;
    z-index: 1;
  }

  .button:hover::before,
  .button[data-state="playing"]::before {
    opacity: 1;
  }

  .button:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 1px;
    border-radius: 50%;
  }

  @media (max-width: 640px) {
    .card {
      border-radius: 16px;
    }

    .content {
      gap: 0.8rem;
    }

    .art {
      border-radius: 10px;
    }

    .title {
      font-size: 1.2rem;
    }

    .actions {
      margin: 0.5rem 1.5rem 1rem;
      gap: 0.75rem;
      justify-content: center;
    }

    .button {
      width: 34px;
      height: 32px;
      min-height: 32px;
    }

    .play-icon {
      width: 1.2rem;
      height: 1.2rem;
    }
  }
</style>
