---
import type { Card } from "../data/cards";

interface Props {
  card: Card;
  "data-set"?: string;
}

const { card, ...props } = Astro.props;
const hasSource = card.source.length > 0;
const hasImage = card.image.length > 0;
---

<article class="card" {...props}>
  <div class="content">
    <a
      class="card-link"
      href={hasSource ? card.source : "#"}
      aria-disabled={!hasSource || undefined}
    >
      <div class="art">
        {
          hasImage ? (
            <img src={card.image} alt={card.title} loading="lazy" />
          ) : (
            <div class="art-placeholder">No image</div>
          )
        }
      </div>
      <div class="meta">
        <h2 class="title">{card.title}</h2>
      </div>
    </a>
    <div class="actions">
      {
        card.audios.map((clip) => (
          <button
            class="button"
            type="button"
            data-state="idle"
            data-label={clip.label}
            data-path={clip.path}
            data-title={card.title}
            aria-pressed="false"
            aria-label={`Play audio: ${card.title} - ${clip.label}`}
          >
            <img src="/images/play-button.png" alt="" class="play-icon" />
          </button>
        ))
      }
    </div>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: transparent;
    border: 1px solid var(--hs-border-subtle);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--hs-shadow);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    border-color: var(--hs-border-strong);
  }

  .card:focus-within {
    outline: 3px solid var(--hs-gold-primary);
    outline-offset: 4px;
  }

  .content {
    display: grid;
    gap: 1rem;
  }

  .card-link {
    display: grid;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .card-link[aria-disabled="true"] {
    cursor: default;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--hs-gold-primary);
    outline-offset: 2px;
  }

  .art {
    aspect-ratio: 375 / 518;
    border-radius: 12px;
    overflow: hidden;
  }

  .art img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .art-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--hs-text-secondary);
    font-size: 0.9rem;
  }

  .meta {
    display: grid;
    padding: 0 1rem;
    gap: 0.5rem;
  }

  .title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    color: var(--hs-text-primary);
    transition: color 0.3s ease;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    min-height: 3.5rem;
    padding: 0;
    border-style: none;
    border-radius: 50%;
    flex: 0 0 auto;
    cursor: pointer;
    background: transparent;
    transition: all 0.3s ease;
  }

  .play-icon {
    width: 80%;
    object-fit: contain;
    pointer-events: none;
  }

  .button:active {
    transform: translateY(0) scale(0.95);
  }

  .button[data-state="playing"] {
    background: linear-gradient(180deg, #9ad9ff 0%, #5bb6ff 100%);
    border-color: rgba(155, 217, 255, 0.5);
    box-shadow: 0 6px 20px rgba(155, 217, 255, 0.4);
  }

  .button[data-state="playing"]:hover {
    box-shadow: 0 8px 24px rgba(155, 217, 255, 0.5);
  }

  .button:focus-visible {
    outline: 3px solid var(--hs-gold-primary);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .card {
      border-radius: 16px;
    }

    .content {
      gap: 0.8rem;
    }

    .art {
      border-radius: 10px;
    }

    .title {
      font-size: 1.2rem;
    }

    .actions {
      flex-direction: row;
      gap: 0.75rem;
      justify-content: center;
    }

    .button {
      width: 3rem;
      height: 3rem;
      min-height: 3rem;
    }

    .play-icon {
      width: 1.75rem;
      height: 1.75rem;
    }
  }
</style>
