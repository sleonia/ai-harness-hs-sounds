---
interface Props {
  sets: string[];
}

const { sets } = Astro.props;
---

<div class="filter-wrapper">
  <label for="set-filter" class="sr-only">Тип карты</label>
  <div class="filter-shell">
    <select
      id="set-filter"
      class="filter-select css-1fyvfgu em9tld4"
      aria-label="Тип карты"
    >
      <option value="all">Все карты</option>
      {sets.map((set) => <option value={set}>{set}</option>)}
    </select>
    <div class="select-arrow" aria-hidden="true">
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M4 6L8 10L12 6"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>
</div>

<style>
  .filter-wrapper {
    margin: 0 auto 2rem;
    width: min(100%, 360px);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .filter-shell {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    height: 42px;
    margin: 0 24px;
    padding-left: 20px;
    background: url("/ui/dropdown_middle.png") center center no-repeat;
    background-size: 100% 100%;
    transition: background-image 0.15s ease-out;
  }

  .filter-shell::before,
  .filter-shell::after {
    content: "";
    position: absolute;
    top: 0;
    width: 24px;
    height: 42px;
    background-size: 24px 42px;
    background-repeat: no-repeat;
    transition: background-image 0.15s ease-out;
  }

  .filter-shell::before {
    left: -24px;
    background-image: url("/ui/dropdown_left.png");
  }

  .filter-shell::after {
    right: -24px;
    background-image: url("/ui/dropdown_right.png");
  }

  .filter-shell:hover,
  .filter-shell:focus-within {
    background-image: url("/ui/dropdown_middle_hover.png");
  }

  .filter-shell:hover::before,
  .filter-shell:focus-within::before {
    background-image: url("/ui/dropdown_left_hover.png");
  }

  .filter-shell:hover::after,
  .filter-shell:focus-within::after {
    background-image: url("/ui/dropdown_right_hover.png");
  }

  .filter-select {
    flex: 1;
    width: 100%;
    height: 100%;
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--hs-brown-text);
    font-family: "Benguiat Bold", Georgia, serif;
    font-size: 1rem;
    line-height: 1;
    padding: 0 2rem 0 0;
    text-shadow: 0 1px 0 rgba(255, 245, 220, 0.6);
    cursor: pointer;
  }

  .filter-select:focus {
    outline: none;
  }

  .select-arrow {
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--hs-brown-text);
    transition: transform 0.15s ease-out;
  }

  .filter-shell:hover .select-arrow,
  .filter-shell:focus-within .select-arrow {
    transform: translateY(-50%) rotate(180deg);
  }

  .filter-select option {
    font-family: "Benguiat Bold", Georgia, serif;
    color: #2b1b0c;
    background: #e7c78e;
  }

  @media (max-width: 768px) {
    .filter-wrapper {
      width: min(100%, 320px);
      margin-bottom: 1.5rem;
    }
  }
</style>
