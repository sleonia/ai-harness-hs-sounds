---
interface Props {
  sets: string[];
}

const { sets } = Astro.props;
---

<div class="filter-wrapper">
  <div class="filter-container">
    <label for="set-filter" class="filter-label">Filter by set:</label>
    <div class="custom-select-wrapper">
      <select
        id="set-filter"
        class="filter-select css-1fyvfgu em9tld4"
        aria-label="Filter by card set"
      >
        <option value="all">All sets</option>
        {sets.map((set) => <option value={set}>{set}</option>)}
      </select>
      <div class="select-arrow">
        <svg
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M2 4L6 8L10 4"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </div>
</div>

<style>
  .filter-wrapper {
    margin-bottom: 2rem;
  }

  .filter-container {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 203, 103, 0.3);
    border-radius: 4px;
  }

  .filter-label {
    color: var(--hs-gold-primary);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .custom-select-wrapper {
    position: relative;
    flex: 1;
    min-width: 280px;
  }

  .filter-select {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    border: 1px solid rgba(255, 203, 103, 0.4);
    border-radius: 2px;
    background: rgba(15, 15, 15, 0.9);
    color: var(--hs-text-primary);
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
      Arial, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-select:hover {
    background: rgba(26, 26, 26, 0.95);
    border-color: var(--hs-gold-secondary);
  }

  .filter-select:focus {
    outline: none;
    background: rgba(26, 26, 26, 0.98);
    border-color: var(--hs-gold-primary);
    box-shadow: 0 0 0 4px rgba(255, 203, 103, 0.2);
  }

  .select-arrow {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--hs-gold-primary);
    transition: transform 0.2s ease;
  }

  .filter-select:focus + .select-arrow {
    transform: translateY(-50%) rotate(180deg);
  }

  .filter-select option {
    background: #1a1a1a;
    color: var(--hs-text-primary);
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    font-family: inherit;
  }

  .filter-select option:hover,
  .filter-select option:checked {
    background: rgba(255, 203, 103, 0.15);
  }

  @media (max-width: 768px) {
    .filter-container {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      padding: 0.875rem;
    }

    .filter-label {
      align-self: flex-start;
    }

    .custom-select-wrapper {
      min-width: 100%;
    }

    .filter-select {
      padding: 0.625rem 2.25rem 0.625rem 0.875rem;
      font-size: 0.875rem;
    }
  }
</style>
