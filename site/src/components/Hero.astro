---
interface Props {
  cardCount: number;
  clipCount: number;
}

const { cardCount, clipCount } = Astro.props;
---

<header class="hero">
  <div class="hero-content">
    <div class="hero-text">
      <h1>Hearthstone Sound Pack</h1>
      <p class="intro">
        Catalog: {cardCount} cards, {clipCount} audio clips from local soundpack files.
      </p>
    </div>
  </div>
</header>

<style>
  .hero {
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(
      135deg,
      rgba(26, 26, 26, 0.6),
      rgba(15, 15, 15, 0.8)
    );
    border: 1px solid var(--hs-border-subtle);
    border-radius: 20px;
    box-shadow: var(--hs-shadow);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4.4rem);
    line-height: 0.95;
    color: var(--hs-gold-primary);
    font-family: var(--hs-font-heading);
    text-shadow: 0 4px 12px rgba(255, 203, 103, 0.15);
  }

  .intro {
    max-width: 62ch;
    margin: 0;
    color: var(--hs-text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 1.5rem;
      margin-bottom: 2rem;
      border-radius: 16px;
    }

    .hero-content {
      gap: 1.5rem;
    }

    h1 {
      font-size: clamp(2rem, 4vw, 3.5rem);
    }

    .intro {
      font-size: 1rem;
    }
  }
</style>
